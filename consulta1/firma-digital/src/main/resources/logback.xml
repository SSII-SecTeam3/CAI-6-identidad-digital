<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Consola: Nivel INFO para el usuario, DEBUG para el desarrollador si se necesita -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Fichero de log rotativo (útil para auditoría en producción) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/firma-digital.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/firma-digital.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Reducir verbosidad de librerías de terceros -->
    <logger name="org.apache.pdfbox" level="WARN"/>
    <logger name="org.apache.xml.security" level="WARN"/>
    <logger name="org.bouncycastle" level="WARN"/>

    <!-- Nivel DEBUG para nuestro código durante el desarrollo -->
    <logger name="es.salud.firma" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
